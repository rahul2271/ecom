datasource db {
  provider = "postgresql"

}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  AFFILIATE
  ADMIN
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String   @unique
  password        String
  role            Role     @default(CUSTOMER)
  affiliateCode   String?  @unique
  totalEarned     Float    @default(0.0)
  
  orders          Order[]      @relation("CustomerOrders")
  referrals       Order[]      @relation("AffiliateOrders")
  withdrawals     Withdrawal[] @relation("AffiliateWithdrawals")
  createdAt       DateTime     @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  images      String[]
  category    String
  stock       Int      @default(0)
  commission  Float    @default(5.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
}

model Order {
  id              String   @id @default(cuid())
  razorpayOrderId String   @unique
  totalAmount     Float
  status          String   @default("PAID")
  
  customerId      String
  customer        User     @relation("CustomerOrders", fields: [customerId], references: [id])
  
  affiliateId     String?
  affiliate       User?    @relation("AffiliateOrders", fields: [affiliateId], references: [id])
  createdAt       DateTime @default(now())
}

model Withdrawal {
  id          String           @id @default(cuid())
  amount      Float
  status      WithdrawalStatus @default(PENDING)
  affiliateId String
  affiliate   User             @relation("AffiliateWithdrawals", fields: [affiliateId], references: [id])
  createdAt   DateTime         @default(now())
}